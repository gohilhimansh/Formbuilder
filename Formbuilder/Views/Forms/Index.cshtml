@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>
<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h3 class="fw-bold text-dark m-0">
            <i class="fa-solid fa-receipt text-primary me-2"></i>Forms Dashboard
        </h3>
    </div>
    <div class="col-md-6 text-md-end mt-3 mt-md-0">
        <button type="button" class="btn btn-primary-custom shadow-sm" id="btnNewForm">
            <i class="fa-solid fa-plus-circle me-1"></i> New Form
        </button>
    </div>
</div>
<div class="card card-custom">
    <div class="card-body p-4">
        <div class="table-responsive">
            <table id="formTable" class="table table-hover table-striped align-middle table-custom w-100">
                <thead>
                    <tr>
                        <th>Form#</th>
                        <th>Form Name</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
    </div>
</div>

@await Html.PartialAsync("_FormModal")
@section Scripts {
    <script src="~/js/form.js"></script>
}
